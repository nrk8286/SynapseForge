# Bind to loopback behind a reverse proxy in production. Use 0.0.0.0 in a container.
HOST=127.0.0.1
PORT=3101
DATABASE_PATH=./data/synapseforge.db
UPLOAD_DIR=./uploads
PUBLIC_ORIGIN=http://localhost:3101
# Comma-separated additional origins for development only.
ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
# Set true only when traffic reaches the app through HTTPS.
COOKIE_SECURE=false
TRUST_PROXY=0
SESSION_DAYS=14
